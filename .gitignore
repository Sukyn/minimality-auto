# Keep this repository intentionally small: ignore everything by default.
*

# Repository metadata and installation instructions.
!.gitignore
!README.md
!pyproject.toml

# Project documentation.
!docs/
!docs/**/
!docs/**/*.md

# Python tool source code only (never bytecode or cache directories).
!src/
!src/**/
!src/**/*.py

# Test source code.
!tests/
!tests/**/
!tests/**/*.py

# JSON theory/fragments used as tool inputs.
!theories/
!theories/**/
!theories/**/*.json
